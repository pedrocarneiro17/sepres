# Variáveis de ambiente do Sistema DP
# No Railway: configure em "Variables". Localmente: copie para ".env".

# Chave usada para assinar as sessões. Gere uma aleatória e longa.
# Ex.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# Credenciais de acesso ao sistema (tela de login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Fornecida automaticamente pelo Railway ao vincular o banco PostgreSQL.
# Se ausente, o sistema usa um arquivo SQLite local (apenas para desenvolvimento).
# DATABASE_URL=postgresql://usuario:senha@host:porta/banco
